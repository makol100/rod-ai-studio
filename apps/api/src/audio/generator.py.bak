from pathlib import Path
import re
import subprocess


PIPER_BIN = Path("/root/rod-ai-studio/tools/piper/piper/piper")
PIPER_MODEL = Path("/root/rod-ai-studio/tools/piper/voices/pl_PL-darkman-medium.onnx")


def extract_narration(scenes: str) -> list[str]:
    lines = []
    for line in scenes.splitlines():
        line = line.strip()
        if line.startswith("LEKTOR:"):
            text = line.replace("LEKTOR:", "", 1).strip()
            if text:
                lines.append(text)
    return lines


def generate_audio(folder: Path, scenes: str) -> list[dict]:
    audio_dir = folder / "audio"
    audio_dir.mkdir(parents=True, exist_ok=True)

    narrations = extract_narration(scenes)
    results = []

    for idx, text in enumerate(narrations, start=1):
        output = audio_dir / f"{idx:02d}.wav"

        subprocess.run(
            [
                str(PIPER_BIN),
                "-m", str(PIPER_MODEL),
                "-f", str(output),
                "--length_scale", "0.85",
            ],
            input=text,
            text=True,
            check=True,
        )

        results.append({
            "scene": idx,
            "text": text,
            "output": str(output),
        })

    return results
